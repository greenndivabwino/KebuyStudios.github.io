name: 📦 Genera files.json per download

on:
  push:
    branches: ["main"]
    paths:
      - 'downloads/**'  # Si attiva solo quando modifichi downloads/
  workflow_dispatch:    # Eseguibile manualmente

jobs:
  generate-json:
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - name: 📥 Scarica repository
        uses: actions/checkout@v4

      - name: 📂 Genera files.json dalla cartella downloads
        run: |
          # Crea un array JSON con i file della cartella downloads
          cd downloads
          files=()
          for file in *; do
            if [ -f "$file" ]; then
              size=$(stat -c%s "$file" 2>/dev/null || stat -f%z "$file" 2>/dev/null)
              # Formatta la dimensione in KB/MB/GB
              if [ $size -ge 1048576 ]; then
                size_hr="$(echo "scale=2; $size/1048576" | bc) MB"
              elif [ $size -ge 1024 ]; then
                size_hr="$(echo "scale=2; $size/1024" | bc) KB"
              else
                size_hr="${size} B"
              fi
              # Data ultima modifica
              date=$(date -r "$file" +%Y-%m-%d 2>/dev/null || date -r "$file" +%Y-%m-%d)
              files+=("{\"name\":\"$file\",\"size\":\"$size_hr\",\"date\":\"$date\"}")
            fi
          done
          # Scrivi il JSON
          echo "[" > files.json
          for i in "${!files[@]}"; do
            echo "  ${files[$i]}" >> files.json
            if [ $i -lt $((${#files[@]}-1)) ]; then
              echo "," >> files.json
            fi
          done
          echo "]" >> files.json
          cd ..

      - name: ✅ Controlla se ci sono modifiche
        id: git-check
        run: |
          git config --global user.name 'github-actions'
          git config --global user.email 'github-actions@github.com'
          git add downloads/files.json
          if git diff --staged --quiet; then
            echo "changed=false" >> $GITHUB_OUTPUT
          else
            echo "changed=true" >> $GITHUB_OUTPUT
          fi

      - name: 📤 Carica files.json
        if: steps.git-check.outputs.changed == 'true'
        run: |
          git commit -m "Aggiornamento automatico files.json [skip ci]"
          git push
